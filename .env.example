# Required: Anthropic API key
ANTHROPIC_API_KEY=

# Optional: Custom API base URL (e.g., DashScope, OpenRouter)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: Bearer token for third-party API providers
# ANTHROPIC_AUTH_TOKEN=

# Optional: Override the model
# LLM_MODEL=claude-sonnet-4-6

# Optional: Enable integration tests (requires real CLI + API key)
# CLAUDE_SDK_RUN_INTEGRATION=1
